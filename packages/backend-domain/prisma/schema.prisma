generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SausageRawMaterial {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  name         String
  group        String
  unit         String
  warehouseQty Float    @map("warehouse_qty")
  workshopQty  Float    @map("workshop_qty")
  reservedQty  Float    @map("reserved_qty")
  minQty       Float    @map("min_qty")
  status       String
  supplierName String?  @map("supplier_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  recipeItems SausageRecipeItem[]

  @@index([companyId])
  @@map("sausage_raw_materials")
}

model SausageFinishedProduct {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  name          String
  sku           String
  unit          String
  stockQty      Float    @map("stock_qty")
  stockPcs      Float?   @map("stock_pcs")
  reservedQty   Float    @map("reserved_qty")
  shelfLifeDays Float?   @map("shelf_life_days")
  status        String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  recipes SausageRecipe[]

  @@index([companyId])
  @@map("sausage_finished_products")
}

model SausageRecipe {
  id                   String   @id @default(uuid())
  companyId            String   @map("company_id")
  finishedProductId    String   @map("finished_product_id")
  finishedProductName  String   @map("finished_product_name")
  outputQty            Float    @map("output_qty")
  expectedYieldPercent Float    @map("expected_yield_percent")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  finishedProduct SausageFinishedProduct @relation(fields: [finishedProductId], references: [id])
  items           SausageRecipeItem[]

  @@index([companyId])
  @@map("sausage_recipes")
}

model SausageRecipeItem {
  id              String   @id @default(uuid())
  recipeId        String   @map("recipe_id")
  rawMaterialId   String   @map("raw_material_id")
  rawMaterialName String   @map("raw_material_name")
  quantityQty     Float    @map("quantity_qty")

  recipe      SausageRecipe      @relation(fields: [recipeId], references: [id])
  rawMaterial SausageRawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@map("sausage_recipe_items")
}

model SausageClient {
  id               String   @id @default(uuid())
  companyId        String   @map("company_id")
  name             String
  segment          String
  phone            String?
  externalClientId String?  @map("external_client_id")
  balanceAmount    Float?   @map("balance_amount")
  balanceCurrency  String?  @map("balance_currency")
  lastOrderAt      String?  @map("last_order_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("sausage_clients")
}

model SausageProductionOrder {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  number              String
  finishedProductId   String   @map("finished_product_id")
  finishedProductName String   @map("finished_product_name")
  quantityQty         Float    @map("quantity_qty")
  clientId            String?  @map("client_id")
  clientName          String?  @map("client_name")
  status              String
  progressPercent     Float    @map("progress_percent")
  dueAt               String?  @map("due_at")
  shift               String?
  externalOrderId     String?  @map("external_order_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("sausage_production_orders")
}

model SausageProductionBatch {
  id                    String   @id @default(uuid())
  companyId             String   @map("company_id")
  batchNo               String   @map("batch_no")
  productionOrderId     String   @map("production_order_id")
  productionOrderNumber String   @map("production_order_number")
  finishedProductId     String   @map("finished_product_id")
  finishedProductName   String   @map("finished_product_name")
  producedQty           Float    @map("produced_qty")
  acceptedQty           Float    @map("accepted_qty")
  rejectedQty           Float    @map("rejected_qty")
  yieldPercent          Float    @map("yield_percent")
  
  status                String   @default("RELEASED")
  qualityStatus         String   @map("quality_status") @default("NOT_CHECKED")
  plannedQty            Float?   @map("planned_qty")
  varianceQty           Float?   @map("variance_qty")
  variancePercent       Float?   @map("variance_percent")
  
  masterUserId          String?  @map("master_user_id")
  masterName            String?  @map("master_name")
  operatorUserId        String?  @map("operator_user_id")
  operatorName          String?  @map("operator_name")
  
  qualityCheckedByUserId String? @map("quality_checked_by_user_id")
  qualityCheckedByName   String? @map("quality_checked_by_name")
  qualityCheckedAt       DateTime? @map("quality_checked_at")
  qualityNote            String? @map("quality_note")
  
  releasedAt            String   @map("released_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("sausage_production_batches")
}

model SausageStockMovement {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  docNo             String   @map("doc_no")
  type              String
  itemKind          String   @map("item_kind")
  itemId            String   @map("item_id")
  itemName          String   @map("item_name")
  quantityQty       Float    @map("quantity_qty")
  fromLocation      String   @map("from_location")
  toLocation        String   @map("to_location")
  productionOrderId String?  @map("production_order_id")
  productionBatchId String?  @map("production_batch_id")
  createdByUserId   String   @map("created_by_user_id")
  createdByName     String?  @map("created_by_name")
  createdAt         DateTime @default(now()) @map("created_at")
  reason            String?

  @@index([companyId])
  @@map("sausage_stock_movements")
}

model SausageLoss {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  docNo             String   @map("doc_no")
  itemKind          String   @map("item_kind")
  itemId            String   @map("item_id")
  itemName          String   @map("item_name")
  reason            String
  category          String?
  stage             String?
  quantityQty       Float    @map("quantity_qty")
  costAmount        Float?   @map("cost_amount")
  costCurrency      String?  @map("cost_currency")
  productionOrderId String?  @map("production_order_id")
  productionBatchId String?  @map("production_batch_id")
  isRecoverable     Boolean? @map("is_recoverable") @default(false)
  approvedByUserId  String?  @map("approved_by_user_id")
  approvedByName    String?  @map("approved_by_name")
  approvedAt        DateTime? @map("approved_at")
  createdByUserId   String   @map("created_by_user_id")
  createdByName     String?  @map("created_by_name")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([companyId])
  @@map("sausage_losses")
}

model SausageSalesOrder {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  number          String
  clientId        String?  @map("client_id")
  clientName      String?  @map("client_name")
  externalOrderId String?  @map("external_order_id")
  status          String
  requestedDate   String?  @map("requested_date")
  dueDate         String?  @map("due_date")
  note            String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  items SausageSalesOrderItem[]

  @@index([companyId])
  @@map("sausage_sales_orders")
}

model SausageSalesOrderItem {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  salesOrderId        String   @map("sales_order_id")
  finishedProductId   String   @map("finished_product_id")
  finishedProductName String   @map("finished_product_name")
  quantityQty         Float    @map("quantity_qty")
  reservedQty         Float    @default(0) @map("reserved_qty")
  producedQty         Float    @default(0) @map("produced_qty")
  shippedQty          Float    @default(0) @map("shipped_qty")
  shortageQty         Float    @default(0) @map("shortage_qty")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  salesOrder SausageSalesOrder @relation(fields: [salesOrderId], references: [id])

  @@index([companyId])
  @@index([salesOrderId])
  @@map("sausage_sales_order_items")
}

model SausageFinishedGoodsReservation {
  id                  String    @id @default(uuid())
  companyId           String    @map("company_id")
  salesOrderId        String    @map("sales_order_id")
  salesOrderItemId    String    @map("sales_order_item_id")
  finishedProductId   String    @map("finished_product_id")
  finishedProductName String    @map("finished_product_name")
  quantityQty         Float     @map("quantity_qty")
  status              String
  createdByUserId     String    @map("created_by_user_id")
  createdByName       String?   @map("created_by_name")
  createdAt           DateTime  @default(now()) @map("created_at")
  releasedAt          DateTime? @map("released_at")
  completedAt         DateTime? @map("completed_at")
  reason              String?

  @@index([companyId])
  @@map("sausage_finished_goods_reservations")
}

model SausageQualityCheck {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  productionBatchId   String   @map("production_batch_id")
  productionOrderId   String?  @map("production_order_id")
  batchNo             String?  @map("batch_no")
  finishedProductId   String?  @map("finished_product_id")
  finishedProductName String?  @map("finished_product_name")
  checkedQty          Float    @map("checked_qty")
  acceptedQty         Float    @map("accepted_qty")
  rejectedQty         Float    @map("rejected_qty")
  qualityStatus       String   @map("quality_status")
  temperatureCelsius  Float?   @map("temperature_celsius")
  humidityPercent     Float?   @map("humidity_percent")
  sampleWeightQty     Float?   @map("sample_weight_qty")
  note                String?
  checkedByUserId     String   @map("checked_by_user_id")
  checkedByName       String?  @map("checked_by_name")
  checkedAt           DateTime @map("checked_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([productionBatchId])
  @@map("sausage_quality_checks")
}
